  "keyFeatures": [
    "Realtime collaborative markdown editing via Yjs — no file migration required",
    "Mermaid, PlantUML, and Excalidraw diagram support",
    "Source-anchored comments and team chat with collaborator presence",
    "Wiki-links, backlinks, outline, and quick switcher for Obsidian-style vaults",
    "Git-backed vaults with private repo bootstrap via SSH",
    "Optional Cloudflare Quick Tunnel for instant public sharing",
    "Docker and Coolify deployment with persistent volume support",
    "Password authentication for protected public sessions"
  ],
  "publicApiSurface": [
    "collabmd [directory] [options]",
    "--port / -p",
    "--host",
    "--auth (none | password)",
    "--auth-password",
    "--local-plantuml",
    "--no-tunnel",
    "--version / -v",
    "--help / -h",
    "GET /health",
    "WS /ws/:file",
    "COLLABMD_GIT_REPO_URL",
    "COLLABMD_GIT_SSH_PRIVATE_KEY_FILE",
    "COLLABMD_GIT_SSH_PRIVATE_KEY_B64",
    "COLLABMD_GIT_SSH_KNOWN_HOSTS_FILE",
